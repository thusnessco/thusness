# Supabase — from Project Settings → API (or the green "Connect" dialog)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Use ONE of these (Connect dialog uses publishable):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: /inquiry “Optional: gentle wording” → OpenAI-compatible chat completions
# OpenAI (default base): set INQUIRY_LLM_API_KEY only; model defaults to gpt-4o-mini.
# Moonshot / Kimi: set INQUIRY_LLM_BASE_URL=https://api.moonshot.cn/v1 and INQUIRY_LLM_MODEL=moonshot-v1-8k (or current model name from their docs).
# INQUIRY_LLM_API_KEY=
# INQUIRY_LLM_BASE_URL=https://api.openai.com/v1
# INQUIRY_LLM_MODEL=gpt-4o-mini
